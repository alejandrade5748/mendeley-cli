# Example environment file for mendeley-cli.
#
# Copy this file to `.env.test` (or another filename) and fill in the
# values, or export the variables in your shell / CI. NEVER commit a real
# `.env` file — `.env.test`, `.env`, and any `.env.*` filename is
# ignored by `.gitignore`.
#
# Get your OAuth client ID and secret from the Mendeley / Elsevier
# developer portal: https://dev.mendeley.com/ (or its current successor).

# OAuth2 client ID for the app registered on the developer portal.
MENDELEY_CLIENT_ID=replace-me-with-your-client-id

# OAuth2 client secret. Regenerate this on the developer portal if it
# is ever exposed. Treat it like a password.
MENDELEY_CLIENT_SECRET=replace-me-with-your-client-secret

# OAuth2 redirect URI. Must match the value registered for the app on
# the developer portal exactly. The default port (11595) is what
# `mendeley auth login` listens on.
MENDELEY_REDIRECT_URI=http://localhost:11595
